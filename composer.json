{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "akyrey/donezo",
    "type": "project",
    "description": "Donezo - A Things-inspired task management web application.",
    "keywords": ["donezo", "todo", "tasks", "productivity"],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "google/apiclient": "^2.19",
        "inertiajs/inertia-laravel": "^2.0.21",
        "laravel/framework": "^12.53",
        "laravel/octane": "^2.14",
        "laravel/sanctum": "^4.3.1",
        "laravel/socialite": "^5.24.3",
        "laravel/tinker": "^2.11.1",
        "minishlink/web-push": "^10.0.2",
        "spatie/laravel-data": "^4.20",
        "tightenco/ziggy": "^2.6.2"
    },
    "require-dev": {
        "fruitcake/laravel-debugbar": "^4.1.1",
        "barryvdh/laravel-ide-helper": "^3.6.1",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.9.3",
        "laravel/boost": "^2.2.3",
        "laravel/pail": "^1.2.6",
        "laravel/pint": "^1.27.1",
        "laravel/sail": "^1.53",
        "laravel/telescope": "^5.18",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "pestphp/pest": "^4.4.1",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "phpunit/phpunit": "^12.5.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan --no-interaction package:discover"
        ],
        "initiate": [
            "@php artisan --no-interaction --no-ansi migrate --force",
            "@php artisan --no-interaction --no-ansi storage:link",
            "@php artisan --no-interaction --no-ansi optimize:clear",
            "@php artisan --no-interaction --no-ansi event:cache",
            "@php artisan --no-interaction --no-ansi config:cache",
            "@php artisan --no-interaction --no-ansi route:cache",
            "@php artisan --no-interaction --no-ansi data:cache-structures"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:coverage": "@php artisan test --coverage",
        "pint": "vendor/bin/pint",
        "stan": "vendor/bin/phpstan analyse",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
