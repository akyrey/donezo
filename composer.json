{
  "$schema": "https://getcomposer.org/schema.json",
  "name": "akyrey/donezo",
  "type": "project",
  "description": "Donezo - A Things-inspired task management web application.",
  "keywords": [
    "donezo",
    "todo",
    "tasks",
    "productivity"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "google/apiclient": "^2.19.2",
    "inertiajs/inertia-laravel": "^3.0.6",
    "laravel/framework": "^12.58.0",
    "laravel/horizon": "^5.46.0",
    "laravel/octane": "^2.17.2",
    "laravel/reverb": "^1.10.0",
    "laravel/sanctum": "^4.3.1",
    "laravel/socialite": "^5.26.1",
    "laravel/tinker": "^2.11.1",
    "laravel/wayfinder": "^0.1.16",
    "minishlink/web-push": "^10.0.3",
    "sentry/sentry-laravel": "^4.25",
    "spatie/laravel-data": "^4.22.1",
    "spatie/laravel-permission": "^7.3.0",
    "symfony/http-client": "^8.0.8",
    "symfony/mailgun-mailer": "^8.0"
  },
  "require-dev": {
    "fruitcake/laravel-debugbar": "^4.2.8",
    "barryvdh/laravel-ide-helper": "^3.7.0",
    "fakerphp/faker": "^1.24.1",
    "larastan/larastan": "^3.9.6",
    "laravel/boost": "^2.4.5",
    "laravel/pail": "^1.2.6",
    "laravel/pint": "^1.29.1",
    "laravel/telescope": "^5.20",
    "mockery/mockery": "^1.6.12",
    "nunomaduro/collision": "^8.9.4",
    "pestphp/pest": "^4.6.3",
    "pestphp/pest-plugin-laravel": "^4.1.0",
    "phpunit/phpunit": "^12.5.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "build": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan --no-interaction package:discover"
    ],
    "initiate": [
      "@php artisan --no-interaction --no-ansi migrate --force",
      "@php artisan --no-interaction --no-ansi storage:link",
      "@php artisan --no-interaction --no-ansi optimize:clear",
      "@php artisan --no-interaction --no-ansi event:cache",
      "@php artisan --no-interaction --no-ansi config:cache",
      "@php artisan --no-interaction --no-ansi route:cache",
      "@php artisan --no-interaction --no-ansi data:cache-structures"
    ],
    "dev": [
      "Composer\\Config::disableProcessTimeout",
      "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74,#86efac\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" \"php artisan reverb:start\" --names=server,queue,logs,vite,reverb --kill-others"
    ],
    "test": [
      "@php artisan config:clear --ansi",
      "pest --parallel"
    ],
    "test:coverage": "@php artisan test --coverage",
    "pint": "vendor/bin/pint",
    "stan": "vendor/bin/phpstan analyse",
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi",
      "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
      "@php artisan migrate --graceful --ansi"
    ],
    "pre-package-uninstall": [
      "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": [
        "laravel/telescope"
      ]
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
